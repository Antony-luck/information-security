# 应用基础配置
APP_NAME=面向短视频多模态融合的内容安全智能研判系统
APP_VERSION=0.1.0

# 目录配置
MODEL_DIR=models
UPLOAD_DIR=data/uploads
CACHE_DIR=data/cache
STATIC_DIR=app/static

# ASR 配置（优先本地离线）
VIDEO_ASR_MODEL_NAME=tiny
VIDEO_ASR_MODEL_PATH=
VIDEO_ASR_MODEL_DIR=models/asr
VIDEO_ASR_OFFLINE_ONLY=1
# 示例：
# VIDEO_ASR_MODEL_PATH=models/asr/tiny

# 大模型 API 配置（OpenAI-compatible）
LLM_PROVIDER=qwen
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_API_PATH=/chat/completions
LLM_TIMEOUT_SECONDS=60

# 事实核查检索配置
FACT_CHECK_SEARCH_ENABLED=1
FACT_CHECK_MAX_QUERIES=3
FACT_CHECK_TIMEOUT_SECONDS=10
